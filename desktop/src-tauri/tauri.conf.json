{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dmanager-desktop",
  "version": "0.1.0",
  "identifier": "com.dmanager.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "dmanager-desktop",
        "width": 1380,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/backend", "resources/jre"],
    "targets": ["msi", "dmg", "appimage", "deb", "rpm", "app"],
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      }
    }
  }
}
